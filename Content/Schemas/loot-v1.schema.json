{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amandacore.local/schemas/loot-v1.schema.json",
  "title": "AmandaCore Loot Catalog v1",
  "type": "object",
  "required": ["loot_tables"],
  "additionalProperties": false,
  "properties": {
    "loot_tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["loot_table_id", "entries"],
        "properties": {
          "loot_table_id": { "$ref": "#/$defs/content_id" },
          "allow_empty": { "type": "boolean" },
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["item_id", "min_quantity", "max_quantity", "drop_chance_percent"],
              "properties": {
                "item_id": { "$ref": "#/$defs/content_id" },
                "min_quantity": { "type": "integer", "minimum": 1 },
                "max_quantity": { "type": "integer", "minimum": 1 },
                "drop_chance_percent": { "type": "number", "minimum": 0, "maximum": 100 },
                "guaranteed": { "type": "boolean" },
                "tags": { "$ref": "#/$defs/string_list" }
              }
            }
          },
          "tags": { "$ref": "#/$defs/string_list" }
        }
      }
    }
  },
  "$defs": {
    "content_id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$" },
    "string_list": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
