{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amandacore.local/schemas/vendor-v1.schema.json",
  "title": "AmandaCore Vendor Catalog v1",
  "type": "object",
  "required": ["vendors"],
  "additionalProperties": false,
  "properties": {
    "vendors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["vendor_id", "display_name", "items"],
        "properties": {
          "vendor_id": { "$ref": "#/$defs/content_id" },
          "display_name": { "type": "string", "minLength": 1 },
          "npc_id": { "$ref": "#/$defs/content_id" },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["item_id", "price_copper"],
              "properties": {
                "item_id": { "$ref": "#/$defs/content_id" },
                "price_copper": { "type": "integer", "minimum": 0 },
                "stack_limit": { "type": "integer", "minimum": 0 },
                "available": { "type": "boolean" },
                "tags": { "$ref": "#/$defs/string_list" }
              }
            }
          },
          "tags": { "$ref": "#/$defs/string_list" }
        }
      }
    }
  },
  "$defs": {
    "content_id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$" },
    "string_list": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
