{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amandacore.local/schemas/item-v1.schema.json",
  "title": "AmandaCore Item Catalog v1",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "display_name", "kind", "quality", "max_stack"],
        "properties": {
          "item_id": { "$ref": "#/$defs/content_id" },
          "display_name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "kind": {
            "enum": ["weapon", "armor", "consumable", "material", "quest", "junk", "currency", "equipment"]
          },
          "quality": { "enum": ["poor", "common", "uncommon", "rare", "epic"] },
          "max_stack": { "type": "integer", "minimum": 1 },
          "tags": { "$ref": "#/$defs/string_list" }
        }
      }
    }
  },
  "$defs": {
    "content_id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$" },
    "string_list": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
