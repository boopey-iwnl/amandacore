{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amandacore.local/schemas/content-package-v1.schema.json",
  "title": "AmandaCore Content Package v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["package_id", "display_name", "version", "schema_version", "zones"],
  "properties": {
    "package_id": { "$ref": "#/$defs/content_id" },
    "display_name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "1" },
    "description": { "type": "string" },
    "authorship": { "type": "string" },
    "continent_files": { "$ref": "#/$defs/path_list" },
    "zones": { "$ref": "#/$defs/path_list" },
    "map_exports": { "$ref": "#/$defs/path_list" },
    "npc_catalogs": { "$ref": "#/$defs/path_list" },
    "item_catalogs": { "$ref": "#/$defs/path_list" },
    "loot_catalogs": { "$ref": "#/$defs/path_list" },
    "quest_catalogs": { "$ref": "#/$defs/path_list" },
    "ability_catalogs": { "$ref": "#/$defs/path_list" },
    "aura_catalogs": { "$ref": "#/$defs/path_list" },
    "vendor_catalogs": { "$ref": "#/$defs/path_list" },
    "trainer_catalogs": { "$ref": "#/$defs/path_list" },
    "dialogue_catalogs": { "$ref": "#/$defs/path_list" },
    "hook_catalogs": { "$ref": "#/$defs/path_list" },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/content_id" },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "content_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "path_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "not": { "pattern": "^[A-Za-z]:|^/|\\.\\." }
      },
      "uniqueItems": true
    }
  }
}
